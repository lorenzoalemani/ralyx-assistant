# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com

# ─── IA — Chat ────────────────────────────────────────────────────────────────
# Proveedor activo: "mock" | "groq"
AI_PROVIDER=mock

# Groq — tier gratuito en https://console.groq.com
GROQ_API_KEY=tu-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── IA — Embeddings (RAG) ────────────────────────────────────────────────────
# Proveedor activo: "openai"
# Para agregar Gemini u Ollama: ver src/lib/embeddings/provider.ts
EMBEDDING_PROVIDER=openai

# OpenAI — requerido para embeddings
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Modelo de embeddings (afecta las dimensiones del vector)
#   text-embedding-3-small → 1536 dims (recomendado)
#   text-embedding-3-large → 3072 dims (mayor precisión, mayor costo)
# Si cambiás el modelo, ejecutá una migración para alterar vector(N)
# y reindexá con reindexBusiness()
OPENAI_EMBEDDING_MODEL=text-embedding-3-small