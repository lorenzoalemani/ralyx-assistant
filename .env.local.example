# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── Encriptación de tokens ───────────────────────────────────────────────────
# Clave AES-256-GCM para encriptar tokens de acceso por negocio.
# Generar una sola vez: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA cambiar en producción — invalidaría todos los tokens guardados.
TOKEN_ENCRYPTION_KEY=

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
# Token global de sistema para WhatsApp (un solo número por app)
# Cuando WhatsApp sea multi-tenant, migrará a tokens por negocio en DB
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com

# Webhook unificado para todos los canales de Meta:
# https://tu-app.vercel.app/api/webhook/meta

# ─── IA — Chat ────────────────────────────────────────────────────────────────
# Proveedor activo: "mock" | "groq"
AI_PROVIDER=mock

# Groq — tier gratuito en https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── IA — Embeddings (RAG) ────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small